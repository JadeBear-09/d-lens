ENV=dev
LOG_LEVEL=INFO
DLENS_API_KEY=

DATABASE_URL=postgresql+psycopg://dlens:dlens@postgres:5432/dlens
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=dlens_reports

# GCP MVP option for Cloud Run + Cloud SQL.
# Leave DATABASE_URL unset/default and set these in Cloud Run instead:
# INSTANCE_UNIX_SOCKET=/cloudsql/YOUR_PROJECT:YOUR_REGION:dlens-postgres
# DB_USER=dlens
# DB_PASS=stored_in_secret_manager
# DB_NAME=dlens

RETRIEVAL_SCORE_THRESHOLD=0.60
LATENCY_SPIKE_MS=5000
MINOR_LATENCY_MS=3000
TOKEN_COST_SPIKE=3000

# Optional. Service works without this key using deterministic RCA + hash embeddings.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
